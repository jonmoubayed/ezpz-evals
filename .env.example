# Copy to .env and fill in. The CLI auto-loads ./.env before every command (real env vars win).
# Values are referenced by NAME from adapter configs (api_key_env: ...); never commit real keys.
# .env is gitignored.

# LLM adapters
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Extend.ai (managed extraction)
EXTEND_API_KEY=

# LlamaIndex: backend LLM key (e.g. OPENAI_API_KEY above) + LlamaParse cloud key
LLAMA_CLOUD_API_KEY=
